# EcoRouter edge TLS — replace eco.you.dev with your domain.
# Install: sudo cp deploy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy

eco.you.dev {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8080

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		-Server
	}

	request_body {
		max_size 10MB
	}
}
